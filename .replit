modules = ["nodejs-20", "python-3.11", "web"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Browser Agent Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova Chat"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Nova Mobile"

[[workflows.workflow]]
name = "Browser Agent Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8000 uv run python3 artifacts/browser-agent-server/main.py"
waitForPort = 8000

[[workflows.workflow]]
name = "Nova Chat"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/nova-chat run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Nova Mobile"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=3001 BASE_PATH=/mobile/ pnpm --filter @workspace/nova-mobile run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "webview"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["gitFull", "playwright-driver", "glib", "nss", "nspr", "atk", "at-spi2-atk", "xorg.libX11", "xorg.libxcb", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "xorg.libXrender", "cups", "dbus", "expat", "fontconfig", "freetype", "pango", "gtk3", "alsa-lib", "libdrm", "mesa", "chromium"]

[[ports]]
localPort = 8000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8080

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 23842
externalPort = 3001

[[ports]]
localPort = 23843
externalPort = 3000

[userenv]

[userenv.shared]
OLLAMA_URL = "http://localhost:11434"
